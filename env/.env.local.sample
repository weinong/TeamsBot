# Copy to env/.env.local and fill in.

# Bot Framework / Teams identity (leave blank for local emulator with no auth)
BOT_ID=
BOT_TENANT_ID=
BOT_TYPE=MultiTenant

# Option A: client secret
BOT_PASSWORD=

# Option B: client certificate (PEM files). If BOT_CERT_PATH and BOT_CERT_KEY_PATH
# are both set, the bot uses certificate auth and BOT_PASSWORD is ignored.
# BOT_CERT_THUMBPRINT is optional; if blank it is computed from BOT_CERT_PATH.
BOT_CERT_PATH=
BOT_CERT_KEY_PATH=
BOT_CERT_THUMBPRINT=

# HTTP port the bot listens on
PORT=3978

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
# Optional. Leave blank to use DefaultAzureCredential (az login locally,
# UAMI in Azure Container Apps).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
# Optional. UAMI client ID to prefer when multiple identities are attached.
# Container Apps injects this automatically when a single UAMI is bound.
AZURE_CLIENT_ID=
# Set to "true" to force reasoning-model param scrubbing (max_completion_tokens,
# drop temperature/top_p/penalties). Auto-detected by deployment name prefix
# (o1/o3/o4/gpt-5) when left blank.
AZURE_OPENAI_REASONING_MODEL=

# RAG tuning
FAQ_FILE=data/faq.md
FAQ_TOP_K=4
