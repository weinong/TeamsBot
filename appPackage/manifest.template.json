{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "version": "0.1.0",
  "id": "2a165570-d361-48a2-bc05-2eccaa53c541",
  "packageName": "com.example.teamsfaqbot",
  "developer": {
    "name": "Weinong Wang",
    "websiteUrl": "https://eng.ms",
    "privacyUrl": "https://eng.ms/privacy",
    "termsOfUseUrl": "https://eng.ms/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
    "short": "FAQ Bot",
    "full": "FAQ Bot powered by Azure OpenAI"
  },
  "description": {
    "short": "Ask questions and get answers from our FAQ.",
    "full": "An AI-powered Teams bot that answers questions using a curated FAQ knowledge base via retrieval-augmented generation."
  },
  "accentColor": "#FFFFFF",
  "bots": [
    {
      "botId": "${BOT_APP_ID}",
      "scopes": ["personal", "team", "groupchat"],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal", "team", "groupchat"],
          "commands": [
            { "title": "reset", "description": "Reset the conversation" }
          ]
        }
      ]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": []
}
