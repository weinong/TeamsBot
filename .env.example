# Environment variables sourced by scripts/*.ps1 and the Teams app build.
# Copy to .env (gitignored) and `dot-source` it before running scripts, e.g.:
#
#   PowerShell:
#     Get-Content .env | ForEach-Object {
#       if ($_ -match '^\s*([^#=][^=]*)=(.*)$') { Set-Item -Path "env:$($Matches[1].Trim())" -Value $Matches[2].Trim() }
#     }
#
# All values shown are placeholders.

# Azure subscription that hosts the bot resources (used by scripts/deploy.ps1,
# scripts/build-image.ps1, scripts/update.ps1).
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Bot Framework app id == UAMI clientId of the user-assigned managed identity that
# the Azure Bot resource and Container App run under. Used to render the Teams app
# manifest from appPackage/manifest.template.json.
# After `scripts/deploy.ps1`, retrieve it with:
#   az identity show -g <ResourceGroup> -n uami-<NamePrefix> --query clientId -o tsv
BOT_APP_ID=00000000-0000-0000-0000-000000000000
